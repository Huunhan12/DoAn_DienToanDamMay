<%- include('partials/header.ejs') %>
<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold"><i class="fas fa-calendar-check me-2 text-primary"></i>Chấm Công Hàng Ngày</h3>
    <div class="d-flex align-items-center">
        <button type="button" class="btn btn-outline-success btn-sm me-3 fw-bold" onclick="markAllPresent()">
            <i class="fas fa-check-double me-2"></i>Chấm tất cả "Có mặt"
        </button>
        <form action="/chamcong" method="GET" class="d-flex align-items-center">
            <label class="me-2 text-nowrap">Chọn ngày:</label>
            <% 
                const today = new Date().toISOString().split('T')[0];
            %>
            <input type="date" name="date" class="form-control form-control-sm" value="<%= currentDate %>" max="<%= today %>" onchange="this.form.submit()">
        </form>
    </div>
</div>

<div class="card shadow-sm">
    <form action="/chamcong/update" method="POST">
        <input type="hidden" name="date" value="<%= currentDate %>">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0 align-middle">
                    <thead>
                        <tr>
                            <th>Mã NV</th>
                            <th>Họ Tên</th>
                            <th>Trạng Thái Chấm</th>
                            <th>Ghi Chú</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if(typeof data !== 'undefined' && data.length > 0) { %>
                            <% data.forEach((nv, index) => { %>
                                <tr>
                                    <td class="fw-bold text-primary"><%= nv.maNV %></td>
                                    <td><%= nv.hoTen %></td>
                                    <td>
                                        <div class="d-flex gap-2">
                                            <div class="form-check form-check-inline">
                                                <input class="form-check-input" type="radio" name="attendance[<%= nv._id %>][status]" id="status_co_<%= nv._id %>" value="Có mặt" <%= nv.trangThai === 'Có mặt' ? 'checked' : '' %>>
                                                <label class="form-check-label text-success" for="status_co_<%= nv._id %>">Có mặt</label>
                                            </div>
                                            <div class="form-check form-check-inline">
                                                <input class="form-check-input" type="radio" name="attendance[<%= nv._id %>][status]" id="status_vang_<%= nv._id %>" value="Vắng mặt" <%= nv.trangThai === 'Vắng mặt' ? 'checked' : '' %>>
                                                <label class="form-check-label text-danger" for="status_vang_<%= nv._id %>">Vắng</label>
                                            </div>
                                            <div class="form-check form-check-inline">
                                                <input class="form-check-input" type="radio" name="attendance[<%= nv._id %>][status]" id="status_tre_<%= nv._id %>" value="Đi trễ" <%= nv.trangThai === 'Đi trễ' ? 'checked' : '' %>>
                                                <label class="form-check-label text-warning" for="status_tre_<%= nv._id %>">Đi trễ</label>
                                            </div>
                                            <div class="form-check form-check-inline">
                                                <input class="form-check-input" type="radio" name="attendance[<%= nv._id %>][status]" id="status_phep_<%= nv._id %>" value="Nghỉ phép" <%= nv.trangThai === 'Nghỉ phép' ? 'checked' : '' %>>
                                                <label class="form-check-label text-primary" for="status_phep_<%= nv._id %>">Phép</label>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <input type="text" name="attendance[<%= nv._id %>][note]" class="form-control form-control-sm" value="<%= nv.ghiChu %>" placeholder="...">
                                    </td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr>
                                <td colspan="4" class="text-center py-5 text-muted">Không có nhân viên nào để chấm công.</td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
        <% if(typeof data !== 'undefined' && data.length > 0) { %>
            <div class="card-footer bg-white border-top text-end py-3">
                <button type="submit" class="btn btn-primary px-4 shadow-sm fw-bold">
                    <i class="fas fa-save me-2"></i>Lưu Chấm Công
                </button>
            </div>
        <% } %>
    </form>
</div>

<script>
    function markAllPresent() {
        // Tìm tất cả các radio button có giá trị "Có mặt" và chọn chúng
        const presentRadios = document.querySelectorAll('input[type="radio"][value="Có mặt"]');
        presentRadios.forEach(radio => {
            radio.checked = true;
        });
    }
</script>

<%- include('partials/footer.ejs') %>