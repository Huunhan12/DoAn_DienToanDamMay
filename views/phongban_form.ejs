<%- include('partials/header.ejs') %>
<div class="row justify-content-center mt-4">
    <div class="col-md-6">
        <div class="card shadow-lg">
            <div class="card-header bg-primary py-3 d-flex justify-content-between align-items-center">
                <h4 class="mb-0 text-white"><%= pb ? 'Sửa Phòng Ban' : 'Thêm Phòng Ban Mới' %></h4>
                <a href="/phongban" class="btn btn-sm btn-light">Quay lại</a>
            </div>
            <div class="card-body p-4">
                <form action="<%= pb ? '/phongban/sua/' + pb._id : '/phongban/them' %>" method="POST">
                    <div class="mb-3">
                        <label class="form-label text-muted">Mã Phòng Ban <span class="text-danger">*</span></label>
                        <input type="text" name="maPhongBan" class="form-control bg-dark-subtle border-secondary text-white" value="<%= pb ? pb.maPhongBan : '' %>" required <%= pb ? 'readonly' : '' %>>
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-muted">Tên Phòng Ban <span class="text-danger">*</span></label>
                        <input type="text" name="tenPhongBan" class="form-control bg-dark-subtle border-secondary text-white" value="<%= pb ? pb.tenPhongBan : '' %>" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-muted">Mô Tả</label>
                        <textarea name="moTa" class="form-control bg-dark-subtle border-secondary text-white" rows="3"><%= pb ? pb.moTa : '' %></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-muted">Ngày Thành Lập</label>
                        <input type="date" name="ngayThanhLap" class="form-control bg-dark-subtle border-secondary text-white" value="<%= pb && pb.ngayThanhLap ? pb.ngayThanhLap.toISOString().split('T')[0] : '' %>">
                    </div>
                    <div class="mt-4 text-end">
                        <button type="submit" class="btn btn-primary px-5 fw-bold shadow-sm">
                            <i class="fas fa-save me-2"></i><%= pb ? 'Cập Nhật' : 'Lưu Phòng Ban' %>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
<%- include('partials/footer.ejs') %>
