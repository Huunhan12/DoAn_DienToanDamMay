<%- include('partials/header.ejs') %>
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 fw-bold">Tổng Quan Hệ Thống</h1>
    <div>
        <span class="text-muted"><%= new Date().toLocaleDateString('vi-VN') %></span>
    </div>
</div>

<% if(user.vaiTro === 'user') { %>
    <!-- Dashboard cho User -->
    <div class="row g-4">
        <div class="col-md-12">
            <div class="card border-0 shadow-sm p-4 text-center bg-primary text-white mb-4">
                <div class="py-5">
                    <i class="fas fa-user-circle fa-5x mb-3"></i>
                    <h2 class="fw-bold">Xin chào, <%= user.hoTen %>!</h2>
                    <p class="lead opacity-75">Chào mừng bạn quay lại hệ thống quản lý nội bộ.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <a href="/nhanvien" class="text-decoration-none h-100">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body text-center py-5">
                        <div class="fs-1 text-primary mb-3 bg-aliceblue d-inline-flex p-4 rounded-circle shadow-sm"><i class="fas fa-id-card"></i></div>
                        <h4 class="fw-bold text-dark mt-2">Hồ Sơ Của Tôi</h4>
                        <p class="text-muted small">Xem và kiểm tra thông tin cá nhân</p>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-4">
            <a href="/chamcong" class="text-decoration-none h-100">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body text-center py-5">
                        <div class="fs-1 text-success mb-3 bg-light-success d-inline-flex p-4 rounded-circle shadow-sm"><i class="fas fa-calendar-check"></i></div>
                        <h4 class="fw-bold text-dark mt-2">Chấm Công</h4>
                        <p class="text-muted small">Kiểm tra lịch sử đi làm</p>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-4">
            <a href="/salary" class="text-decoration-none h-100">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body text-center py-5">
                        <div class="fs-1 text-warning mb-3 bg-light-warning d-inline-flex p-4 rounded-circle shadow-sm"><i class="fas fa-money-bill-wave"></i></div>
                        <h4 class="fw-bold text-dark mt-2">Bảng Lương</h4>
                        <p class="text-muted small">Xem phiếu lương cá nhân hàng tháng</p>
                    </div>
                </div>
            </a>
        </div>
    </div>
<% } else { %>
    <!-- Dashboard cho Admin -->
    <div class="row g-4 mb-5">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm overflow-hidden stat-widget-card" style="border-left: 6px solid #3b82f6 !important;">
                <div class="card-body d-flex align-items-center py-4">
                    <div class="fs-1 me-4 text-primary bg-aliceblue p-4 rounded-circle shadow-sm"><i class="fas fa-users"></i></div>
                    <div>
                        <h5 class="card-title text-muted mb-1 fw-bold">Tổng Nhân Viên</h5>
                        <h2 class="fw-extrabold mb-0 text-primary"><%= typeof countNhanVien !== 'undefined' ? countNhanVien : 0 %></h2>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm overflow-hidden stat-widget-card" style="border-left: 6px solid #10b981 !important;">
                <div class="card-body d-flex align-items-center py-4">
                    <div class="fs-1 me-4 text-success bg-light-success p-4 rounded-circle shadow-sm"><i class="fas fa-building"></i></div>
                    <div>
                        <h5 class="card-title text-muted mb-1 fw-bold">Tổng Phòng Ban</h5>
                        <h2 class="fw-extrabold mb-0 text-success"><%= typeof countPhongBan !== 'undefined' ? countPhongBan : 0 %></h2>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm overflow-hidden stat-widget-card" style="border-left: 6px solid #f59e0b !important;">
                <div class="card-body d-flex align-items-center py-4">
                    <div class="fs-1 me-4 text-warning bg-light-warning p-4 rounded-circle shadow-sm"><i class="fas fa-briefcase"></i></div>
                    <div>
                        <h5 class="card-title text-muted mb-1 fw-bold">Tổng Chức Vụ</h5>
                        <h2 class="fw-extrabold mb-0 text-warning"><%= typeof countChucVu !== 'undefined' ? countChucVu : 0 %></h2>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
            <h5 class="mb-0 fw-bold"><i class="fas fa-user-plus me-2 text-primary"></i>Nhân Viên Mới</h5>
            <a href="/nhanvien" class="btn btn-sm btn-outline-primary">Xem tất cả</a>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0 align-middle">
                    <thead>
                        <tr>
                            <th>Mã NV</th>
                            <th>Họ Tên</th>
                            <th>Phòng Ban</th>
                            <th>Chức Vụ</th>
                            <th>Ngày Vào Làm</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if(typeof nhanVienMoi !== 'undefined' && nhanVienMoi.length > 0) { %>
                            <% nhanVienMoi.forEach(nv => { %>
                                <tr>
                                    <td><%= nv.maNV %></td>
                                    <td>
                                        <div class="d-flex align-items-center justify-content-start">
                                            <div class="avatar-sm bg-secondary rounded-circle me-2 d-flex justify-content-start align-items-center" style="width:32px;height:32px">
                                                <i class="fas fa-user text-light"></i>
                                            </div>
                                            <span class="fw-medium"><%= nv.hoTen %></span>
                                        </div>
                                    </td>
                                    <td><%= nv.phongBan ? nv.phongBan.tenPhongBan : 'Chưa xếp' %></td>
                                    <td><span class="badge bg-secondary"><%= nv.chucVu ? nv.chucVu.tenChucVu : 'Chưa xếp' %></span></td>
                                    <td><%= new Date(nv.ngayVaoLam).toLocaleDateString('vi-VN') %></td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr>
                                <td colspan="5" class="text-center py-4 text-muted">Chưa có nhân viên nào!</td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
<% } %>
<%- include('partials/footer.ejs') %>