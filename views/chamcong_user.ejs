<%- include('partials/header.ejs') %>
<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold"><i class="fas fa-calendar-alt me-2 text-primary"></i>Lịch Sử Chấm Công Cá Nhân</h3>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0 align-middle">
                <thead class="bg-light">
                    <tr>
                        <th>Ngày</th>
                        <th>Trạng Thái</th>
                        <th>Ghi Chú</th>
                    </tr>
                </thead>
                <tbody>
                    <% if(typeof data !== 'undefined' && data.length > 0) { %>
                        <% data.forEach(item => { %>
                            <tr>
                                <td class="fw-bold"><%= item.ngayChamCong.toLocaleDateString('vi-VN') %></td>
                                <td>
                                    <% if(item.trangThai === 'Có mặt') { %>
                                        <span class="badge bg-success"><i class="fas fa-check me-1"></i><%= item.trangThai %></span>
                                    <% } else if(item.trangThai === 'Vắng mặt') { %>
                                        <span class="badge bg-danger"><i class="fas fa-times me-1"></i><%= item.trangThai %></span>
                                    <% } else if(item.trangThai === 'Đi trễ') { %>
                                        <span class="badge bg-warning text-dark"><i class="fas fa-clock me-1"></i><%= item.trangThai %></span>
                                    <% } else { %>
                                        <span class="badge bg-primary"><i class="fas fa-info-circle me-1"></i><%= item.trangThai %></span>
                                    <% } %>
                                </td>
                                <td class="text-muted"><%= item.ghiChu || '---' %></td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="3" class="text-center py-5 text-muted">Bạn chưa có dữ liệu chấm công nào.</td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>
<%- include('partials/footer.ejs') %>
