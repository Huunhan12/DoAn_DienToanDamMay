<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
    <style>
        body {
            background-color: #fff;
            font-family: 'Times New Roman', Times, serif;
            color: #000;
        }
        .invoice-box {
            max-width: 800px;
            margin: auto;
            padding: 30px;
            border: 1px solid #eee;
            box-shadow: 0 0 10px rgba(0, 0, 0, 0.15);
            font-size: 16px;
            line-height: 24px;
        }
        .header-section {
            display: flex;
            justify-content: space-between;
            margin-bottom: 20px;
        }
        .company-info h4 {
            font-weight: bold;
            text-transform: uppercase;
            margin-bottom: 5px;
        }
        .national-motto {
            text-align: center;
        }
        .national-motto h5 {
            font-size: 1.2rem;
            font-weight: bold;
            margin-bottom: 2px;
        }
        .main-title {
            text-align: center;
            margin: 20px 0;
        }
        .main-title h4 {
            font-size: 1rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 1px;
        }
        .info-table {
            width: 100%;
            margin-bottom: 20px;
        }
        .info-table td {
            padding: 5px 0;
        }
        .info-label {
            width: 150px;
            font-weight: bold;
        }
        .salary-table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 20px;
        }
        .salary-table th, .salary-table td {
            border: 1px solid #000;
            padding: 10px;
            text-align: left;
        }
        .salary-table th {
            background-color: #f2f2f2;
        }
        .text-right {
            text-align: right !important;
        }
        .signature-section {
            margin-top: 50px;
            display: flex;
            justify-content: space-around;
        }
        .signature-box {
            text-align: center;
        }
        .signature-box span {
            display: block;
            margin-bottom: 80px;
            font-style: italic;
        }
        @media print {
            .no-print {
                display: none;
            }
            .invoice-box {
                box-shadow: none;
                border: none;
                width: 100%;
                max-width: 100%;
                padding: 0;
            }
            body {
                margin: 1cm;
            }
        }
    </style>
</head>
<body onload="window.print()">
    <div class="container my-4 no-print text-center">
        <button onclick="window.print()" class="btn btn-primary btn-lg">
            <i class="fas fa-print me-2"></i>In Phiếu Lương
        </button>
        <a href="/salary" class="btn btn-outline-secondary btn-lg ms-3">Quay lại</a>
    </div>

    <div class="invoice-box">
        <div class="header-section" style="display: block; text-align: center;">
            <div class="national-motto">
                <h5>CỘNG HÒA XÃ HỘI CHỦ NGHĨA VIỆT NAM</h5>
                <p>Độc lập - Tự do - Hạnh phúc</p>
                <hr style="width: 50%; margin: 10px auto; border-top: 2px solid #000;">
            </div>
        </div>

        <div class="main-title">
            <h4>BẢNG LƯƠNG NHÂN VIÊN</h4>
            <p>Tháng <%= thang %></p>
        </div>

        <table class="info-table">
            <tr>
                <td class="info-label">Mã nhân viên:</td>
                <td><%= nv.maNV %></td>
            </tr>
            <tr>
                <td class="info-label">Họ tên:</td>
                <td style="font-weight: bold; font-size: 1.1em;"><%= nv.hoTen %></td>
            </tr>
            <tr>
                <td class="info-label">Phòng ban:</td>
                <td><%= nv.phongBan ? nv.phongBan.tenPhongBan : '---' %></td>
            </tr>
            <tr>
                <td class="info-label">Chức vụ:</td>
                <td><%= nv.chucVu ? nv.chucVu.tenChucVu : '---' %></td>
            </tr>
            <tr>
                <td class="info-label">Ngày xuất:</td>
                <td><%= ngayXuat %></td>
            </tr>
        </table>

        <table class="salary-table">
            <thead>
                <tr>
                    <th style="width: 50px;">TT</th>
                    <th>Diễn giải khoản mục</th>
                    <th>Định mức / Hệ số</th>
                    <th>Đơn giá (VNĐ)</th>
                    <th>Thành tiền (VNĐ)</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>1</td>
                    <td style="text-align: left;">Lương cơ bản (theo ngày công)</td>
                    <td><%= ngayCong %> ngày</td>
                    <td class="text-right">
                        <%= Math.round((nv.luongCoBan * heSo) / 26).toLocaleString('vi-VN') %>
                    </td>
                    <td class="text-right">
                        <%= Math.round(((nv.luongCoBan * heSo) / 26) * ngayCong).toLocaleString('vi-VN') %>
                    </td>
                </tr>
                <tr>
                    <td>2</td>
                    <td style="text-align: left;">Phụ cấp trách nhiệm / khác</td>
                    <td>---</td>
                    <td class="text-right"><%= nv.phuCap.toLocaleString('vi-VN') %></td>
                    <td class="text-right"><%= nv.phuCap.toLocaleString('vi-VN') %></td>
                </tr>
                <tr>
                    <td colspan="4" class="text-right" style="font-weight: bold;">Tổng cộng tiền lương thực nhận:</td>
                    <td class="text-right" style="font-weight: bold; font-size: 1.2em; color: #000;">
                        <%= tongLuong.toLocaleString('vi-VN') %>
                    </td>
                </tr>
            </tbody>
        </table>

        <div class="signature-section">
            <div class="signature-box">
                <p style="font-weight: bold;">Người nhận lương</p>
                <span>(Ký và ghi rõ họ tên)</span>
            </div>
            <div class="signature-box">
                <p style="font-weight: bold;">Người lập bảng</p>
                <span>(Ký và ghi rõ họ tên)</span>
            </div>
            <div class="signature-box">
                <p style="font-weight: bold;">Giám đốc</p>
                <span>(Ký tên, đóng dấu)</span>
            </div>
        </div>
    </div>

    <!-- FontAwesome -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/js/all.min.js"></script>
</body>
</html>
