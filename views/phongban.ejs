<%- include('partials/header.ejs') %>
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold"><i class="fas fa-building me-2 text-primary"></i>Danh Sách Phòng Ban</h3>
        <a href="/phongban/them" class="btn btn-primary shadow-sm">
            <i class="fas fa-plus me-2"></i>Thêm Phòng Ban
        </a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0 align-middle">
                    <thead>
                        <tr>
                            <th>Mã Phòng</th>
                            <th>Tên Phòng Ban</th>
                            <th>Mô Tả</th>
                            <th>Ngày Thành Lập</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if(typeof data !=='undefined' && data.length> 0) { %>
                            <% data.forEach(pb=> { %>
                                <tr>
                                    <td class="fw-bold text-primary">
                                        <%= pb.maPhongBan %>
                                    </td>
                                    <td class="fw-bold">
                                        <%= pb.tenPhongBan %>
                                    </td>
                                    <td class="text-muted">
                                        <%= pb.moTa %>
                                    </td>
                                    <td>
                                        <%= pb.ngayThanhLap ? pb.ngayThanhLap.toLocaleDateString('vi-VN') : '---' %>
                                    </td>
                                    <td>
                                        <div class="action-buttons">
                                            <a href="/phongban/sua/<%= pb._id %>"
                                                class="btn btn-sm btn-outline-warning">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            <form action="/phongban/xoa/<%= pb._id %>?_method=DELETE" method="POST"
                                                class="d-inline"
                                                onsubmit="return confirm('Bạn có chắc muốn xóa phòng ban này?');">
                                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                                    <i class="fas fa-trash"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                                <% }) %>
                                    <% } else { %>
                                        <tr>
                                            <td colspan="5" class="text-center py-5 text-muted text-uppercase small">
                                                Chưa có phòng ban nào</td>
                                        </tr>
                                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <%- include('partials/footer.ejs') %>