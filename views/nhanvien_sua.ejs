<%- include('partials/header.ejs') %>
<div class="row justify-content-center">
    <div class="col-md-10">
        <div class="card shadow-lg">
            <div class="card-header bg-primary py-3 d-flex justify-content-between align-items-center">
                <h4 class="mb-0 text-white"><i class="fas fa-user-edit me-2"></i>Chỉnh Sửa Nhân Viên</h4>
                <a href="/nhanvien" class="btn btn-sm btn-light"><i class="fas fa-arrow-left me-1"></i>Quay lại</a>
            </div>
            <div class="card-body p-4">
                <form action="/nhanvien/sua/<%= nv._id %>" method="POST">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label text-muted">Mã Nhân Viên</label>
                            <input type="text" name="maNV" class="form-control bg-dark-subtle border-secondary text-white" value="<%= nv.maNV %>" readonly>
                        </div>
                        <div class="col-md-8">
                            <label class="form-label text-muted">Họ và Tên <span class="text-danger">*</span></label>
                            <input type="text" name="hoTen" class="form-control bg-dark-subtle border-secondary text-white" value="<%= nv.hoTen %>" required>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label text-muted">Ngày Sinh <span class="text-danger">*</span></label>
                            <% 
                                const eighteenYearsAgo = new Date();
                                eighteenYearsAgo.setFullYear(eighteenYearsAgo.getFullYear() - 18);
                                const maxDate = eighteenYearsAgo.toISOString().split('T')[0];
                            %>
                            <input type="date" name="ngaySinh" class="form-control bg-dark-subtle border-secondary text-white" value="<%= nv.ngaySinh ? nv.ngaySinh.toISOString().split('T')[0] : '' %>" required max="<%= maxDate %>">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label text-muted">Giới Tính</label>
                            <select name="gioiTinh" class="form-select bg-dark-subtle border-secondary text-white">
                                <option value="Nam" <%= nv.gioiTinh === 'Nam' ? 'selected' : '' %>>Nam</option>
                                <option value="Nữ" <%= nv.gioiTinh === 'Nữ' ? 'selected' : '' %>>Nữ</option>
                                <option value="Khác" <%= nv.gioiTinh === 'Khác' ? 'selected' : '' %>>Khác</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label text-muted">Số Điện Thoại</label>
                            <input type="text" name="soDienThoai" class="form-control bg-dark-subtle border-secondary text-white" value="<%= nv.soDienThoai %>">
                        </div>

                        <div class="col-md-6">
                            <label class="form-label text-muted">Email</label>
                            <input type="email" name="email" class="form-control bg-dark-subtle border-secondary text-white" value="<%= nv.email %>">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-muted">Địa Chỉ</label>
                            <input type="text" name="diaChi" class="form-control bg-dark-subtle border-secondary text-white" value="<%= nv.diaChi %>">
                        </div>

                        <div class="col-md-4">
                            <label class="form-label text-muted">Phòng Ban</label>
                            <select name="phongBan" class="form-select bg-dark-subtle border-secondary text-white" <%= user && user.vaiTro === 'user' ? 'disabled' : '' %>>
                                <option value="">--- Chọn phòng ban ---</option>
                                <% if(typeof phongbans !== 'undefined') { %>
                                    <% phongbans.forEach(pb => { %>
                                        <option value="<%= pb._id %>" <%= nv.phongBan && nv.phongBan.toString() === pb._id.toString() ? 'selected' : '' %>><%= pb.tenPhongBan %></option>
                                    <% }) %>
                                <% } %>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label text-muted">Chức Vụ</label>
                            <select name="chucVu" class="form-select bg-dark-subtle border-secondary text-white" <%= user && user.vaiTro === 'user' ? 'disabled' : '' %>>
                                <option value="">--- Chọn chức vụ ---</option>
                                <% if(typeof chucvus !== 'undefined') { %>
                                    <% chucvus.forEach(cv => { %>
                                        <option value="<%= cv._id %>" <%= nv.chucVu && nv.chucVu.toString() === cv._id.toString() ? 'selected' : '' %>><%= cv.tenChucVu %></option>
                                    <% }) %>
                                <% } %>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label text-muted">Trạng Thái</label>
                            <select name="trangThai" class="form-select bg-dark-subtle border-secondary text-white" <%= user && user.vaiTro === 'user' ? 'disabled' : '' %>>
                                <option value="Đang làm việc" <%= nv.trangThai === 'Đang làm việc' ? 'selected' : '' %>>Đang làm việc</option>
                                <option value="Đã nghỉ việc" <%= nv.trangThai === 'Đã nghỉ việc' ? 'selected' : '' %>>Đã nghỉ việc</option>
                            </select>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label text-muted">Lương Cơ Bản</label>
                            <input type="number" name="luongCoBan" class="form-control bg-dark-subtle border-secondary text-white" value="<%= nv.luongCoBan %>" <%= user && user.vaiTro === 'user' ? 'readonly' : '' %>>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label text-muted">Phụ Cấp</label>
                            <input type="number" name="phuCap" class="form-control bg-dark-subtle border-secondary text-white" value="<%= nv.phuCap %>" <%= user && user.vaiTro === 'user' ? 'readonly' : '' %>>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label text-muted">Ngày Vào Làm</label>
                            <input type="date" name="ngayVaoLam" class="form-control bg-dark-subtle border-secondary text-white" value="<%= nv.ngayVaoLam ? nv.ngayVaoLam.toISOString().split('T')[0] : '' %>">
                        </div>
                    </div>

                    <div class="mt-4 text-end">
                        <button type="submit" class="btn btn-warning px-5 shadow-sm fw-bold">Cập Nhật Thông Tin</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
<%- include('partials/footer.ejs') %>
